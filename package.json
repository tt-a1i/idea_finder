{
  "name": "idea-finder",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --build",
    "lint": "npm run typecheck && npm run test",
    "cli": "npm run build -w @idea-finder/workspace && node packages/workspace/dist/cli/bin.js",
    "web:dev": "npm run dev -w @idea-finder/web",
    "web:build": "npm run build -w @idea-finder/web",
    "web:typecheck": "npm run typecheck -w @idea-finder/web"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.5"
  }
}
